# Gemini API Key for AI-powered verse recommendations
GEMINI_API_KEY=your_gemini_api_key

# OAuth Configuration for Quran Foundation
# Get your credentials from: https://api-docs.quran.foundation/docs/tutorials/oidc/client-setup
QURAN_FOUNDATION_CLIENT_ID=your_client_id_here
QURAN_FOUNDATION_CLIENT_SECRET=your_client_secret_here

# OAuth Base URL (no specific path, just the host)
# For development (local Hydra): http://localhost:5444
# For prelive: https://prelive-oauth2.quran.foundation
# For production: https://oauth2.quran.foundation
QURAN_FOUNDATION_OAUTH_BASE_URL=https://prelive-oauth2.quran.foundation

# API Base URL (no specific path, just the host)
# For prelive: https://apis-prelive.quran.foundation
# For production: https://apis.quran.foundation
QURAN_FOUNDATION_API_BASE_URL=https://apis-prelive.quran.foundation

# Session Secret for cookie encryption (generate a random string)
SESSION_SECRET=your_random_session_secret_here

# Public Origin (your app's URL)
NEXT_PUBLIC_ORIGIN=http://localhost:3050

# Node Environment
NODE_ENV=development
